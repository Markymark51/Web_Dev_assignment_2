<div class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                    <strong><%= user.username %></strong> - <%= user.email %>
                    <% if (user.user_type === 'admin') { %>
                        <span class="badge bg-success ms-2">Admin</span>
                    <% } else {%>
                        <span class="badge bg-secondary ms-2">User</span>
                    <% } %>
                </div>
                <div>
                    <form action="/promoteUser" method="POST" class="d-inline me-2">
                        <input type="hidden" name="username" value="<%= user.username %>">
                        <button class="btn btn-primary btn-sm" type="submit">Promote</button>
                    </form>
                    <form action="/demoteUser" method="POST" class="d-inline">
                        <input type="hidden" name="username" value="<%= user.username %>">
                        <button class="btn btn-danger btn-sm" type="submit">Demote</button>
                    </form>
                </div>
            </div>